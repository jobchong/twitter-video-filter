{
  "manifest_version": 3,
  "name": "Twitter Video Filter",
  "version": "1.0.0",
  "description": "Blocks posts containing video content on the Twitter/X home timeline",
  "permissions": [],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
